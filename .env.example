# Session secret for cookie signing
SESSION_SECRET=your_super_secret_session_key_here

# Google OAuth 2.0 Credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth Credentials
# Get from: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password

# HTTPS/SSL
# For production behind nginx, leave empty and let nginx terminate TLS.
# For direct HTTPS, set paths to your certificate and key files.
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
HTTPS_CA_PATH=

# Environment
NODE_ENV=development
PORT=3000

# CORS allowed origins (comma-separated). Set to your production domain(s) for production.
CORS_ORIGIN=http://localhost:3000

# Google OAuth callback (must match the URI in your Google Cloud console)
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Facebook OAuth callback (must match the URI in your Facebook app settings)
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback